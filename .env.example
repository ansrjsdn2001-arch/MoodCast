# MoodCast environment variables
# Copy the values you need into local .env files and keep secrets out of Git.

## Frontend
VITE_BACKSERVER=http://localhost:8080
VITE_PUBLIC_S3_BASE_URL=

## Backend
PORT=8080
SQL_INIT_MODE=never

DATABASE_URL=jdbc:mysql://localhost:3306/moodcast
DATABASE_USER=
DATABASE_PASSWORD=

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_SECRET=
JWT_ISSUER=moodcast
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=14
JWT_REFRESH_COOKIE_NAME=moodcast_refresh_token
JWT_REFRESH_COOKIE_SAME_SITE=Lax
JWT_REFRESH_COOKIE_SECURE=false

SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER_NUMBER=

KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_ALLOWED_REDIRECT_URIS=http://localhost:5173/auth/kakao/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ALLOWED_REDIRECT_URIS=http://localhost:5173/auth/google/callback

NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_ALLOWED_REDIRECT_URIS=http://localhost:5173/auth/naver/callback

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

APP_PUBLIC_BASE_URL=http://localhost:8080
APP_LOCAL_UPLOAD_RESOURCE_ENABLED=false
APP_DEV_RETURN_AUTH_CODE=false
APP_TRUST_FORWARDED_HEADERS=false

AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_UPLOAD_BUCKET_NAME=
